# Dead Lead Reactivation — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# Database
DATABASE_URL=postgresql://localhost:5432/cinchit_reactivation

# Apollo.io
APOLLO_API_KEY=your_apollo_key_here

# SendGrid (email)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=outreach@getcinchmsp.com
SENDGRID_FROM_NAME=Cinch IT Boston

# Twilio (SMS + Voice)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# OpenAI (for AI response classification)
OPENAI_API_KEY=your_openai_key_here

# Google Places (business verification)
GOOGLE_PLACES_API_KEY=your_google_key_here

# App
APP_SECRET_KEY=generate_a_random_secret_here
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# Test mode — when true, all outreach goes to test contact ONLY
TEST_MODE=true
TEST_CONTACT_NAME=Jamie Erickson
TEST_CONTACT_EMAIL=Erickson.JamesD@gmail.com
TEST_CONTACT_PHONE=+15084049628
